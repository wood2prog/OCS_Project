@page "/customers"
@inject ICustomerService CustomerService

<PageTitle>Customers</PageTitle>

<div class="two-column-layout">
    <div class="col-list">
        <div class="list-toolbar">
            <input class="search-input" type="text" placeholder="Search customers…" @bind="_search" @bind:after="HandleSearch" />
            <button class="add-button" @onclick="HandleAdd">Add Customer</button>
        </div>

        <div class="customer-list">
            @foreach (var c in _filteredCustomers)
            {
                <div class="customer-row @(c.Id == _selectedCustomer?.Id ? "selected" : "")"
                     @onclick="() => HandleSelect(c)">
                    <span class="customer-name">@c.Name</span>
                    <span class="customer-contact">@PrimaryContact(c)</span>
                </div>
            }
            @if (_filteredCustomers.Count == 0)
            {
                <p class="empty-list">No customers found.</p>
            }
        </div>
    </div>

    <div class="col-detail">
        @if (_selectedCustomer is not null)
        {
            <div class="detail-header">
                <h2 class="detail-title">@_selectedCustomer.Name</h2>
                <div class="detail-actions">
                    <span class="job-count-badge">@_selectedCustomer.JobCount job(s)</span>
                    <button class="edit-button" @onclick="HandleEdit">Edit</button>
                    <button class="delete-button-sm" @onclick="HandleInitiateDelete">Delete</button>
                </div>
            </div>

            <div class="detail-fields">
                <div class="field">
                    <label>Name</label>
                    <span>@_selectedCustomer.Name</span>
                </div>
                <div class="field">
                    <label>Email</label>
                    <span>@(_selectedCustomer.Email ?? "—")</span>
                </div>
                <div class="field">
                    <label>Phone</label>
                    <span>@(_selectedCustomer.Phone ?? "—")</span>
                </div>
                <div class="field">
                    <label>Notes</label>
                    <span>@(_selectedCustomer.Notes ?? "—")</span>
                </div>
            </div>
        }
        else
        {
            <div class="empty-detail">
                <p>Select a customer to view details</p>
            </div>
        }
    </div>
</div>

@if (_showAddModal)
{
    <div class="modal-backdrop">
        <div class="modal-card" @onclick:stopPropagation>
            <h3 class="modal-title">Add Customer</h3>

            <div class="modal-form">
                <div class="form-group">
                    <label for="add-name">Name</label>
                    <input id="add-name" type="text" @bind="_addName" />
                </div>
                <div class="form-group">
                    <label for="add-email">Email</label>
                    <input id="add-email" type="email" @bind="_addEmail" />
                </div>
                <div class="form-group">
                    <label for="add-phone">Phone</label>
                    <input id="add-phone" type="text" @bind="_addPhone" />
                </div>
                <div class="form-group">
                    <label for="add-notes">Notes</label>
                    <textarea id="add-notes" @bind="_addNotes"></textarea>
                </div>

                <div class="modal-actions">
                    <button class="cancel-button" @onclick="HandleAddCancel" type="button">Cancel</button>
                    <button class="create-button" disabled="@(string.IsNullOrWhiteSpace(_addName))"
                            @onclick="HandleAddSave" type="button">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showEditModal && _editCustomer is not null)
{
    <div class="modal-backdrop">
        <div class="modal-card" @onclick:stopPropagation>
            <h3 class="modal-title">Edit Customer</h3>

            <div class="modal-form">
                <div class="form-group">
                    <label for="edit-name">Name</label>
                    <input id="edit-name" type="text" @bind="_editName" />
                </div>
                <div class="form-group">
                    <label for="edit-email">Email</label>
                    <input id="edit-email" type="email" @bind="_editEmail" />
                </div>
                <div class="form-group">
                    <label for="edit-phone">Phone</label>
                    <input id="edit-phone" type="text" @bind="_editPhone" />
                </div>
                <div class="form-group">
                    <label for="edit-notes">Notes</label>
                    <textarea id="edit-notes" @bind="_editNotes"></textarea>
                </div>

                <div class="modal-actions">
                    <button class="cancel-button" @onclick="HandleEditCancel" type="button">Cancel</button>
                    <button class="save-button" disabled="@(string.IsNullOrWhiteSpace(_editName))"
                            @onclick="HandleEditSave" type="button">Save Changes</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm && _deleteCustomer is not null)
{
    <div class="modal-backdrop">
        <div class="modal-card confirmation-card" @onclick:stopPropagation>
            <h3 class="modal-title">Delete Customer</h3>
            <p class="confirm-message">Are you sure you want to delete <strong>@_deleteCustomer.Name</strong>? This action cannot be undone.</p>

            @if (!string.IsNullOrEmpty(_deleteErrorMessage))
            {
                <p class="delete-error">@_deleteErrorMessage</p>
            }

            <div class="modal-actions">
                <button class="cancel-button" @onclick="HandleDeleteCancel" type="button">Cancel</button>
                <button class="delete-button" @onclick="HandleDeleteConfirm" type="button">Delete</button>
            </div>
        </div>
    </div>
}

<style>
    .two-column-layout {
        display: flex;
        height: calc(100vh - 3.5rem);
        margin: -1rem -1.5rem;
    }
    .col-list {
        width: 320px;
        min-width: 280px;
        border-right: 1px solid #ddd;
        display: flex;
        flex-direction: column;
    }
    .col-detail {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }
    .list-toolbar {
        padding: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border-bottom: 1px solid #eee;
    }
    .search-input {
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9rem;
    }
    .add-button {
        padding: 0.5rem 1rem;
        background: #1976d2;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .add-button:hover { background: #1565c0; }
    .customer-list {
        flex: 1;
        overflow-y: auto;
    }
    .customer-row {
        padding: 0.75rem;
        cursor: pointer;
        border-bottom: 1px solid #f0f0f0;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }
    .customer-row:hover { background: #f5f5f5; }
    .customer-row.selected { background: #e3f2fd; }
    .customer-name { font-weight: 500; font-size: 0.95rem; }
    .customer-contact { font-size: 0.8rem; color: #777; }
    .empty-list { padding: 1rem; color: #999; text-align: center; }
    .empty-detail { display: flex; align-items: center; justify-content: center; height: 100%; color: #999; }
    .detail-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .detail-title { margin: 0; font-size: 1.3rem; }
    .detail-actions { display: flex; align-items: center; gap: 0.5rem; }
    .job-count-badge { background: #e3f2fd; color: #1976d2; padding: 0.25rem 0.5rem; border-radius: 4px; font-size: 0.8rem; }
    .edit-button { padding: 0.4rem 0.8rem; background: #f5f5f5; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
    .edit-button:hover { background: #e0e0e0; }
    .delete-button-sm { padding: 0.4rem 0.8rem; background: #fff; border: 1px solid #d32f2f; color: #d32f2f; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
    .delete-button-sm:hover { background: #ffebee; }
    .detail-fields { display: flex; flex-direction: column; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: 0.25rem; }
    .field label { font-size: 0.8rem; color: #777; text-transform: uppercase; letter-spacing: 0.5px; }
    .field span { font-size: 0.95rem; }
    .modal-backdrop { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-card { background: #fff; border-radius: 8px; padding: 1.5rem; width: 400px; max-width: 90vw; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .confirmation-card { width: 360px; }
    .modal-title { margin: 0 0 1rem 0; font-size: 1.2rem; color: #333; }
    .modal-form { display: flex; flex-direction: column; gap: 0.75rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.25rem; }
    .form-group label { font-size: 0.85rem; color: #555; }
    .form-group input, .form-group select, .form-group textarea { padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.9rem; }
    .form-group textarea { min-height: 60px; resize: vertical; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 0.5rem; }
    .cancel-button { padding: 0.5rem 1rem; background: #f5f5f5; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; }
    .create-button, .save-button { padding: 0.5rem 1rem; background: #1976d2; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    .create-button:disabled, .save-button:disabled { background: #b0bec5; cursor: not-allowed; }
    .delete-button { padding: 0.5rem 1rem; background: #d32f2f; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    .delete-button:hover { background: #b71c1c; }
    .confirm-message { color: #555; margin-bottom: 1rem; }
    .delete-error { color: #d32f2f; font-size: 0.85rem; margin-bottom: 0.5rem; background: #ffebee; padding: 0.5rem; border-radius: 4px; }
</style>

@code {
    private List<Customer> _customers = [];
    private List<Customer> _filteredCustomers = [];
    private Customer? _selectedCustomer;
    private string _search = string.Empty;

    private bool _showAddModal;
    private string _addName = string.Empty;
    private string? _addEmail;
    private string? _addPhone;
    private string? _addNotes;

    private bool _showEditModal;
    private Customer? _editCustomer;
    private string _editName = string.Empty;
    private string? _editEmail;
    private string? _editPhone;
    private string? _editNotes;

    private bool _showDeleteConfirm;
    private Customer? _deleteCustomer;
    private string? _deleteErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetCustomersAsync();
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_search))
            _filteredCustomers = [.. _customers];
        else
            _filteredCustomers = [.. _customers.Where(c => c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase))];
    }

    private void HandleSearch()
    {
        ApplyFilter();
    }

    private static string PrimaryContact(Customer c)
    {
        return c.Email ?? c.Phone ?? "No contact";
    }

    private void HandleSelect(Customer customer)
    {
        _selectedCustomer = customer;
    }

    private void HandleAdd()
    {
        _addName = string.Empty;
        _addEmail = null;
        _addPhone = null;
        _addNotes = null;
        _showAddModal = true;
    }

    private async Task HandleAddSave()
    {
        var created = await CustomerService.CreateCustomerAsync(new CreateCustomerRequest
        {
            Name = _addName,
            Email = _addEmail,
            Phone = _addPhone,
            Notes = _addNotes,
        });

        _showAddModal = false;
        _customers = await CustomerService.GetCustomersAsync();
        ApplyFilter();
        _selectedCustomer = created;
    }

    private void HandleAddCancel()
    {
        _showAddModal = false;
    }

    private void HandleEdit()
    {
        if (_selectedCustomer is null) return;
        _editCustomer = _selectedCustomer;
        _editName = _selectedCustomer.Name;
        _editEmail = _selectedCustomer.Email;
        _editPhone = _selectedCustomer.Phone;
        _editNotes = _selectedCustomer.Notes;
        _showEditModal = true;
    }

    private async Task HandleEditSave()
    {
        if (_editCustomer is null) return;

        var updated = await CustomerService.UpdateCustomerAsync(_editCustomer.Id, new UpdateCustomerRequest
        {
            Name = _editName,
            Email = _editEmail,
            Phone = _editPhone,
            Notes = _editNotes,
        });

        _showEditModal = false;
        _editCustomer = null;

        _customers = await CustomerService.GetCustomersAsync();
        ApplyFilter();
        _selectedCustomer = updated;
    }

    private void HandleEditCancel()
    {
        _showEditModal = false;
        _editCustomer = null;
    }

    private void HandleInitiateDelete()
    {
        if (_selectedCustomer is null) return;
        _deleteCustomer = _selectedCustomer;
        _deleteErrorMessage = null;
        _showDeleteConfirm = true;
    }

    private async Task HandleDeleteConfirm()
    {
        if (_deleteCustomer is null) return;

        try
        {
            await CustomerService.DeleteCustomerAsync(_deleteCustomer.Id);
            _customers.RemoveAll(c => c.Id == _deleteCustomer.Id);

            if (_selectedCustomer?.Id == _deleteCustomer.Id)
                _selectedCustomer = null;

            _showDeleteConfirm = false;
            _deleteCustomer = null;
            ApplyFilter();
        }
        catch (HttpRequestException ex) when (ex.Message.Contains("409"))
        {
            _deleteErrorMessage = "Cannot delete: this customer has associated jobs.";
        }
    }

    private void HandleDeleteCancel()
    {
        _showDeleteConfirm = false;
        _deleteCustomer = null;
        _deleteErrorMessage = null;
    }
}
