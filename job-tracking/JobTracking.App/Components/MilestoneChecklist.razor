@namespace JobTracking.App.Components
@using JobTracking.App.Models

<div class="job-card">
    <h2 class="job-name">@Job.JobName</h2>
    <div class="stepper">
        @{
            var activeMilestone = Job.Milestones
                .Where(m => m.CompletedAt == null)
                .MinBy(m => m.Order);
        }
        @foreach (var milestone in Job.Milestones)
        {
            var isCompleted = milestone.CompletedAt != null;
            var isActive = !isCompleted && milestone == activeMilestone;
            var stepClass = isCompleted ? "step-completed" : isActive ? "step-active" : "step-locked";

            <div class="step-node @stepClass" @onclick="() => HandleClick(milestone, isActive)">
                <div class="step-indicator">
                    @if (isCompleted)
                    {
                        <span class="step-checkmark">&#10003;</span>
                    }
                    else
                    {
                        <span class="step-number">@milestone.Order</span>
                    }
                </div>
                <div class="step-content">
                    <span class="step-label">@milestone.Label</span>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .job-card {
        max-width: 480px;
        margin: 2rem auto;
        padding: 1.5rem;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-family: system-ui, sans-serif;
    }
    .job-name {
        font-size: 1.25rem;
        margin: 0 0 1.5rem 0;
        color: #333;
    }
    .stepper {
        display: flex;
        flex-direction: column;
    }
    .step-node {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.5rem 0;
        position: relative;
    }
    .step-node::after {
        content: '';
        position: absolute;
        left: 0.95rem;
        top: 2.5rem;
        width: 2px;
        height: calc(100% - 2.5rem);
        background: #e0e0e0;
    }
    .step-node:last-child::after {
        display: none;
    }
    .step-indicator {
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .step-content {
        padding-top: 0.3rem;
    }
    .step-label {
        font-size: 0.95rem;
    }
    .step-completed .step-indicator {
        background: #4caf50;
        color: #fff;
    }
    .step-completed .step-label {
        color: #999;
    }
    .step-active .step-indicator {
        background: #2196f3;
        color: #fff;
    }
    .step-active .step-label {
        color: #333;
        font-weight: 600;
    }
    .step-active {
        cursor: pointer;
    }
    .step-locked .step-indicator {
        background: #e0e0e0;
        color: #999;
    }
    .step-locked .step-label {
        color: #bbb;
    }
    .step-locked {
        cursor: default;
    }
</style>

@code {
    [Parameter]
    public Job Job { get; set; } = null!;

    [Parameter]
    public EventCallback<(int JobId, int MilestoneId, bool Complete)> OnMilestoneToggled { get; set; }

    private void HandleClick(Milestone milestone, bool isActive)
    {
        if (isActive)
            OnMilestoneToggled.InvokeAsync((Job.Id, milestone.Id, true));
    }
}
