@namespace JobTracking.App.Components

<div class="job-list">
    <div class="job-list-toolbar">
        <button class="add-job-button" @onclick="() => OnAddJob.InvokeAsync()">+ Add Job</button>
    </div>
    <h3 class="job-list-header">Jobs</h3>
    <div class="job-list-items" @onclick="() => _openMenuJobId = null">
        @foreach (var job in Jobs)
        {
            <div class="job-row @(SelectedJob?.Id == job.Id ? "selected" : "")"
                 @onclick="() => { _openMenuJobId = null; SelectJob(job); }"
                 @onclick:stopPropagation>
                <div class="job-row-info">
                    <span class="job-row-name">@job.JobName</span>
                    <span class="job-row-detail">#@job.JobNumber - @job.CustomerName</span>
                </div>
                <span class="status-badge status-@job.Status.Replace(" ", "-").ToLowerInvariant()">@job.Status</span>
                <span class="job-row-actions" @onclick:stopPropagation>
                    <button class="kebab-button" @onclick="() => ToggleMenu(job)" @onclick:stopPropagation>&#8942;</button>
                    @if (_openMenuJobId == job.Id)
                    {
                        <div class="kebab-menu" @onclick:stopPropagation>
                            <button class="kebab-edit" @onclick="() => HandleEdit(job)">Edit</button>
                            <button class="kebab-delete" @onclick="() => HandleDelete(job)">Delete</button>
                        </div>
                    }
                </span>
            </div>
        }
    </div>
</div>

<style>
    .job-list {
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    .job-list-toolbar {
        padding: 0.5rem 1rem;
        border-bottom: 1px solid #eee;
    }
    .add-job-button {
        width: 100%;
        padding: 0.5rem;
        background-color: #1976d2;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
    }
    .add-job-button:hover {
        background-color: #1565c0;
    }
    .job-list-header {
        font-size: 1rem;
        margin: 0;
        padding: 1rem;
        border-bottom: 1px solid #eee;
        color: #333;
    }
    .job-list-items {
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        flex: 1;
    }
    .job-row {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f0f0f0;
        transition: background-color 0.1s;
    }
    .job-row:hover {
        background-color: #f5f5f5;
    }
    .job-row.selected {
        background-color: #e3f2fd;
        border-left: 3px solid #1976d2;
        padding-left: calc(1rem - 3px);
    }
    .job-row-info {
        display: flex;
        flex-direction: column;
        flex: 1;
        min-width: 0;
    }
    .job-row-name {
        font-weight: 500;
        color: #333;
    }
    .job-row-detail {
        font-size: 0.8rem;
        color: #777;
    }
    .status-badge {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        background-color: #eee;
        color: #555;
        white-space: nowrap;
        margin-left: auto;
    }
    .status-new { background-color: #e8f5e9; color: #2e7d32; }
    .status-in-design { background-color: #fff3e0; color: #ef6c00; }
    .status-awaiting-approval { background-color: #fff8e1; color: #f57f17; }
    .status-approved { background-color: #e8f5e9; color: #2e7d32; }
    .status-in-production { background-color: #e3f2fd; color: #1565c0; }
    .status-machined { background-color: #f3e5f5; color: #7b1fa2; }
    .status-finished { background-color: #e8f5e9; color: #2e7d32; }
    .status-final-assembly { background-color: #fce4ec; color: #c62828; }
    .status-loaded { background-color: #e0f7fa; color: #00838f; }
    .status-delivered { background-color: #e8f5e9; color: #2e7d32; }
    .status-billing { background-color: #fff3e0; color: #ef6c00; }
    .status-paid { background-color: #e8f5e9; color: #2e7d32; }
    .status-closed { background-color: #f5f5f5; color: #757575; }
    .job-row { position: relative; }
    .job-row-actions { position: relative; display: flex; align-items: center; }
    .kebab-button { background: none; border: none; cursor: pointer; font-size: 1.2rem; color: #777; padding: 0 0.25rem; line-height: 1; }
    .kebab-button:hover { color: #333; }
    .kebab-menu { position: absolute; right: 0; top: 100%; background: #fff; border: 1px solid #ddd; border-radius: 4px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); z-index: 1000; min-width: 100px; }
    .kebab-menu button { display: block; width: 100%; padding: 0.5rem 1rem; border: none; background: none; text-align: left; cursor: pointer; font-size: 0.85rem; }
    .kebab-menu button:hover { background-color: #f5f5f5; }
    .kebab-edit { color: #1976d2; }
    .kebab-delete { color: #d32f2f; }
</style>

@code {
    [Parameter]
    public List<Job> Jobs { get; set; } = [];

    [Parameter]
    public Job? SelectedJob { get; set; }

    [Parameter]
    public EventCallback<Job> OnJobSelected { get; set; }

    [Parameter]
    public EventCallback OnAddJob { get; set; }

    [Parameter]
    public EventCallback<Job> OnEditJob { get; set; }

    [Parameter]
    public EventCallback<Job> OnDeleteJob { get; set; }

    private int? _openMenuJobId;

    private void SelectJob(Job job)
    {
        OnJobSelected.InvokeAsync(job);
    }

    private void ToggleMenu(Job job)
    {
        _openMenuJobId = _openMenuJobId == job.Id ? null : job.Id;
    }

    private async Task HandleEdit(Job job)
    {
        _openMenuJobId = null;
        await OnEditJob.InvokeAsync(job);
    }

    private async Task HandleDelete(Job job)
    {
        _openMenuJobId = null;
        await OnDeleteJob.InvokeAsync(job);
    }
}
