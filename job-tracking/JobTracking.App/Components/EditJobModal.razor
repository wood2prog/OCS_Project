@namespace JobTracking.App.Components

<div class="modal-backdrop">
    <div class="modal-card" @onclick:stopPropagation>
        <h3 class="modal-title">Edit Job</h3>

        <div class="modal-form">
            <div class="form-group">
                <label>Customer</label>
                <span class="customer-label">@Job.CustomerName</span>
            </div>

            <div class="form-group">
                <label for="edit-jobName">Job Name</label>
                <input id="edit-jobName" type="text" @bind="_jobName" />
            </div>

            <div class="form-group">
                <label for="edit-leadDate">Lead Date</label>
                <input id="edit-leadDate" type="date" @bind="_leadDate" />
            </div>

            <div class="form-group">
                <label for="edit-startDate">Start Date</label>
                <input id="edit-startDate" type="date" @bind="_startDate" />
            </div>

            <div class="form-group">
                <label for="edit-deliveryDate">Delivery Date</label>
                <input id="edit-deliveryDate" type="date" @bind="_deliveryDate" />
            </div>

            <div class="form-group">
                <label for="edit-quoteAmount">Quote Amount</label>
                <input id="edit-quoteAmount" type="number" step="0.01" @bind="_quoteAmount" />
            </div>

            <div class="modal-actions">
                <button class="cancel-button" @onclick="HandleCancel" type="button">Cancel</button>
                <button class="save-button" disabled="@(string.IsNullOrWhiteSpace(_jobName))"
                        @onclick="HandleSave" type="button">Save</button>
            </div>
        </div>
    </div>
</div>

<style>
    .modal-backdrop { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-card { background: #fff; border-radius: 8px; padding: 1.5rem; width: 400px; max-width: 90vw; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .modal-title { margin: 0 0 1rem 0; font-size: 1.2rem; color: #333; }
    .modal-form { display: flex; flex-direction: column; gap: 0.75rem; }
    .form-group { display: flex; flex-direction: column; gap: 0.25rem; }
    .form-group label { font-size: 0.85rem; color: #555; }
    .form-group input, .form-group select { padding: 0.5rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.9rem; }
    .customer-label { padding: 0.5rem; background: #f5f5f5; border-radius: 4px; font-size: 0.9rem; color: #333; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 0.5rem; margin-top: 0.5rem; }
    .cancel-button { padding: 0.5rem 1rem; background: #f5f5f5; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; }
    .save-button { padding: 0.5rem 1rem; background: #1976d2; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    .save-button:disabled { background: #b0bec5; cursor: not-allowed; }
</style>

@code {
    [Parameter]
    public Job Job { get; set; } = null!;

    [Parameter]
    public EventCallback<UpdateJobRequest> OnJobUpdated { get; set; }

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    private string _jobName = string.Empty;
    private DateTime? _leadDate;
    private DateTime? _startDate;
    private DateTime? _deliveryDate;
    private decimal? _quoteAmount;

    protected override void OnParametersSet()
    {
        _jobName = Job.JobName;
        _leadDate = Job.LeadDate;
        _startDate = Job.StartDate;
        _deliveryDate = Job.DeliveryDate;
        _quoteAmount = Job.QuoteAmount;
    }

    private async Task HandleSave()
    {
        var request = new UpdateJobRequest
        {
            JobName = _jobName,
            LeadDate = _leadDate,
            StartDate = _startDate,
            DeliveryDate = _deliveryDate,
            QuoteAmount = _quoteAmount,
        };

        await OnJobUpdated.InvokeAsync(request);
    }

    private async Task HandleCancel()
    {
        await OnDismiss.InvokeAsync();
    }
}
