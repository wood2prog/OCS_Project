@namespace JobTracking.App.Components

<div class="modal-backdrop" @onclick="HandleBackdropClick">
    <div class="modal-card" @onclick:stopPropagation>
        <h3 class="modal-title">Add Job</h3>

        <div class="modal-form">
            <div class="form-group">
                <label for="customer">Customer</label>
                <select id="customer" @bind="_customerId">
                    <option value="0" disabled selected>Select a customer…</option>
                    @foreach (var c in Customers)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label for="jobName">Job Name</label>
                <input id="jobName" type="text" @bind="_jobName" />
            </div>

            <div class="form-group">
                <label for="leadDate">Lead Date</label>
                <input id="leadDate" type="date" @bind="_leadDate" />
            </div>

            <div class="form-group">
                <label for="startDate">Start Date</label>
                <input id="startDate" type="date" @bind="_startDate" />
            </div>

            <div class="form-group">
                <label for="deliveryDate">Delivery Date</label>
                <input id="deliveryDate" type="date" @bind="_deliveryDate" />
            </div>

            <div class="form-group">
                <label for="quoteAmount">Quote Amount</label>
                <input id="quoteAmount" type="number" step="0.01" @bind="_quoteAmount" />
            </div>

            <div class="modal-actions">
                <button class="cancel-button" @onclick="HandleCancel" type="button">Cancel</button>
                <button class="create-button" disabled="@(_customerId == 0 || string.IsNullOrWhiteSpace(_jobName))"
                        @onclick="HandleCreate" type="button">Create</button>
            </div>
        </div>
    </div>
</div>

<style>
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,0,0,0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal-card {
        background: #fff;
        border-radius: 8px;
        padding: 1.5rem;
        width: 400px;
        max-width: 90vw;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    }
    .modal-title {
        margin: 0 0 1rem 0;
        font-size: 1.2rem;
        color: #333;
    }
    .modal-form {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .form-group label {
        font-size: 0.85rem;
        color: #555;
    }
    .form-group input,
    .form-group select {
        padding: 0.5rem;
        border: 1px solid #ccc;
        border-radius: 4px;
        font-size: 0.9rem;
    }
    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }
    .cancel-button {
        padding: 0.5rem 1rem;
        background: #f5f5f5;
        border: 1px solid #ccc;
        border-radius: 4px;
        cursor: pointer;
    }
    .create-button {
        padding: 0.5rem 1rem;
        background: #1976d2;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }
    .create-button:disabled {
        background: #b0bec5;
        cursor: not-allowed;
    }
</style>

@code {
    [Parameter]
    public List<Customer> Customers { get; set; } = [];

    [Parameter]
    public EventCallback<CreateJobRequest> OnJobCreated { get; set; }

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    private int _customerId;
    private string _jobName = string.Empty;
    private DateTime? _leadDate;
    private DateTime? _startDate;
    private DateTime? _deliveryDate;
    private decimal? _quoteAmount;

    private async Task HandleCreate()
    {
        var request = new CreateJobRequest
        {
            CustomerId = _customerId,
            JobName = _jobName,
            LeadDate = _leadDate,
            StartDate = _startDate,
            DeliveryDate = _deliveryDate,
            QuoteAmount = _quoteAmount,
        };

        await OnJobCreated.InvokeAsync(request);
    }

    private async Task HandleCancel()
    {
        await OnDismiss.InvokeAsync();
    }

    private async Task HandleBackdropClick()
    {
        await OnDismiss.InvokeAsync();
    }
}
